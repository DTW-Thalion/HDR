from __future__ import annotations

import importlib
import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parent
SRC_ROOT = PROJECT_ROOT / "src"
if str(SRC_ROOT) not in sys.path:
    sys.path.insert(0, str(SRC_ROOT))

from hdr_validation.checkpointing import RunManifest
from hdr_validation.cli import build_parser
from hdr_validation.experiments import STAGE_MODULES
from hdr_validation.packaging import update_final_archives, update_stage_archives, write_checksums
from hdr_validation.reporting import finalize_reports
from hdr_validation.specification import compose_profile_config, config_hash
from hdr_validation.utils import append_markdown_section, ensure_dir, save_text_log, setup_logger, timestamp


def stage_name(stage_id: str) -> str:
    return f"stage_{stage_id}"


def append_failure(project_root: Path, stage: str, profile: str, tb: str) -> None:
    title = f"{stage} / {profile} / {timestamp()}"
    body = f"```\n{tb}\n```"
    append_markdown_section(project_root / "docs" / "FAILURES.md", title, body)
    save_text_log(project_root / "results" / "logs" / f"{stage}_{profile}.traceback.txt", tb)


def run_stage(project_root: Path, stage_id: str, profile_name: str, config: dict, manifest: RunManifest, force: bool, skip_done: bool):
    stage_key = stage_name(stage_id)
    cfg_hash = config_hash(project_root, profile_name, stage_key)
    if manifest.should_skip(stage_key, profile_name, cfg_hash, skip_done=skip_done, force=force):
        return "completed_reused"
    module = importlib.import_module(STAGE_MODULES[stage_id])
    logger = setup_logger(project_root / "results" / "logs" / f"{stage_key}_{profile_name}.log", f"{stage_key}_{profile_name}")
    logger.info("Starting %s %s", stage_key, profile_name)
    manifest.mark_running(stage_key, profile_name, seeds=list(config.get("seeds", [])), config_hash=cfg_hash, notes="running")
    try:
        summary = module.run(project_root, profile_name, config)
        logger.info("Completed %s %s", stage_key, profile_name)
        manifest.mark_completed(stage_key, profile_name, seeds=list(config.get("seeds", [])), config_hash=cfg_hash, output_root=project_root / "results" / stage_key / profile_name)
        return summary
    except Exception as exc:
        tb = manifest.mark_failed(stage_key, profile_name, seeds=list(config.get("seeds", [])), config_hash=cfg_hash, output_root=project_root / "results" / stage_key / profile_name, exc=exc)
        logger.exception("Failed %s %s", stage_key, profile_name)
        append_failure(project_root, stage_key, profile_name, tb)
        return {"status": "failed", "error": str(exc)}
    finally:
        update_stage_archives(project_root, stage_key)


def main():
    parser = build_parser()
    args = parser.parse_args()
    project_root = PROJECT_ROOT
    ensure_dir(project_root / "results")
    manifest = RunManifest(project_root / "results" / "run_manifest.json")

    profiles = [p.strip() for p in args.profiles.split(",") if p.strip()]
    if args.no_extended:
        profiles = [p for p in profiles if p != "extended"]
    stages_raw = [s.strip() for s in args.stages.split(",") if s.strip()]
    # Handle both numeric and alphanumeric stage IDs (e.g. "03b", "03c")
    def _normalise_stage(s: str) -> str:
        # If purely numeric, zero-pad to 2 digits. Otherwise keep as-is.
        if s.isdigit():
            return s.zfill(2)
        return s
    stages = [_normalise_stage(s) for s in stages_raw]
    standard_fail = False

    for profile_name in profiles:
        if profile_name == "extended" and standard_fail:
            cfg = compose_profile_config(project_root, "extended")
            for stage_id in stages:
                manifest.mark_skipped(stage_name(stage_id), profile_name, seeds=list(cfg.get("seeds", [])), config_hash=config_hash(project_root, profile_name, stage_name(stage_id)), notes="skipped because standard profile had failures")
                update_stage_archives(project_root, stage_name(stage_id))
            continue

        config = compose_profile_config(project_root, profile_name)
        for stage_id in stages:
            result = run_stage(project_root, stage_id, profile_name, config, manifest, force=args.force, skip_done=args.skip_done)
            if profile_name == "standard" and isinstance(result, dict) and result.get("status") == "failed":
                standard_fail = True

    finalize_reports(project_root)
    update_final_archives(project_root)
    write_checksums(project_root)
    finalize_reports(project_root)


if __name__ == "__main__":
    main()
