from __future__ import annotations

import argparse


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Run HDR validation stages")
    parser.add_argument("--profiles", default="smoke,standard,extended", help="Comma-separated profiles")
    parser.add_argument("--stages", default="00,01,02,03,03b,03c,04,05,06,07", help="Comma-separated stage ids")
    parser.add_argument("--resume", action="store_true", help="Resume interrupted runs where possible")
    parser.add_argument("--skip-done", action="store_true", help="Skip completed stages when config hash matches")
    parser.add_argument("--force", action="store_true", help="Rerun even if stage is already completed")
    parser.add_argument("--no-extended", action="store_true", help="Do not run the extended profile")
    return parser
