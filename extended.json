from __future__ import annotations

import itertools
from typing import Sequence

import numpy as np


def coherence_penalty(kappa: float, kappa_lo: float, kappa_hi: float) -> float:
    if kappa < kappa_lo:
        return float((kappa - kappa_lo) ** 2)
    if kappa > kappa_hi:
        return float((kappa - kappa_hi) ** 2)
    return 0.0


def coherence_grad(kappa: float, kappa_lo: float, kappa_hi: float) -> float:
    if kappa < kappa_lo:
        return float(2.0 * (kappa - kappa_lo))
    if kappa > kappa_hi:
        return float(2.0 * (kappa - kappa_hi))
    return 0.0


def rolling_plv(signals: np.ndarray) -> float:
    signals = np.asarray(signals, dtype=float)
    if signals.ndim != 2 or signals.shape[0] < 2 or signals.shape[1] < 4:
        return 0.5
    centered = signals - np.mean(signals, axis=1, keepdims=True)
    diff = np.diff(centered, axis=1, prepend=centered[:, :1])
    phases = np.arctan2(diff, centered + 1e-8)
    plvs = []
    for i, j in itertools.combinations(range(signals.shape[0]), 2):
        diff = phases[i] - phases[j]
        plvs.append(np.abs(np.mean(np.exp(1j * diff))))
    return float(np.mean(plvs)) if plvs else 0.5


def coherence_from_state_history(history: np.ndarray, axes: Sequence[int], window: int = 24) -> float:
    hist = np.asarray(history, dtype=float)
    if hist.ndim != 2 or len(hist) < 4:
        return 0.5
    sl = hist[-window:, axes].T
    return rolling_plv(sl)


def settling_metrics(series: np.ndarray, lo: float, hi: float) -> dict[str, float]:
    series = np.asarray(series, dtype=float)
    if series.size == 0:
        return {"time_in_band": float("nan"), "overshoot": float("nan"), "settling_time": float("nan")}
    in_band = (series >= lo) & (series <= hi)
    overshoot = float(max(max(series - hi), max(lo - series), 0.0))
    settling = float(len(series))
    for t in range(len(series)):
        if np.all(in_band[t:]):
            settling = float(t)
            break
    return {"time_in_band": float(np.mean(in_band)), "overshoot": overshoot, "settling_time": settling}
